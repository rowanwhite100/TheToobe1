<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheToobe.NavigationPage"
             >
    <ScrollView Orientation="Vertical">
        <Grid Margin="20,35,20,20"
              RowDefinitions="*, *, *, *, *, *" 
              ColumnDefinitions="100, 50, 100, 50, *"
              Padding="20">

            <Label
                 Text="Station 1"
                     FontFamily="London-Tube"
                    Grid.Column="0"
                    Grid.Row="0"
                    />
            
            <Entry x:Name="Station1_input"
                     Placeholder="Temporary 1"
                     Grid.Column="0"
                    Grid.Row="1"
                     TextChanged="OneTextChanged"
                     />
                   
            <Label 
                    Text="Station 2"
                     FontFamily="London-Tube"
                    Grid.Row="0"
                    Grid.Column="2"
                  
                 />

            <Entry x:Name="Station2_input"
                Placeholder="temp 2"
                 Grid.Column="2"
                Grid.Row="1"
                   TextChanged="TwoTextChanged"
                   />

            <Button x:Name="Initate_button"
                    Text="Entre Staion names"
                    Clicked="OnInitiateClicked"
                    Grid.Row="2"
                    Grid.Column="1"
                    MaximumHeightRequest="75"
                    WidthRequest="150" 
                    IsEnabled="False"
                    Background="#838D93"
                    TextColor="Black">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="Scale"
                                Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Scale"
                                Value="0.8" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PointerOver" />
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </Button>


                <Label
                Text="Output"
                Grid.Column="4"
                Grid.Row="0"
                />

            <Editor
                x:Name="OutputBox"
                Placeholder="Output"
                Grid.Row="2"
                Grid.Column="4"
                MinimumHeightRequest="300"
                MinimumWidthRequest="200"
                IsReadOnly="True"
                />

            <Label Text="Cost"
                       Grid.Column="0"
                       Grid.Row="4"/>
            
            <Entry x:Name="Cost_Entry"
                       Placeholder="Journwy cost"
                       Grid.Column="0"
                       Grid.Row="5"
                        IsReadOnly="True"
                       />

            <Label Text="Time"
           Grid.Column="2"
           Grid.Row="4"/>

            <Entry x:Name="Time_Entry"
           Placeholder="TIME taken"
           Grid.Column="2"
           Grid.Row="5"
           IsReadOnly="True"
           />


        </Grid>
    </ScrollView>
    
</ContentPage>