<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TheToobe.SettingsPage"
             >
    <VerticalStackLayout>

        <Grid Margin="20,20,20,20"
              RowDefinitions="*, *"
              ColumnDefinitions="*, *, *"
              >

            <Label Text="Commuter Mode - DISABLED"
                   x:Name="modeLabel"
                   FontFamily="London-Tube"
                   Grid.Column="0"
                   Grid.Row="0"
                   VerticalTextAlignment="Center"
                   />

            <Switch IsToggled="false"
                    Grid.Column="1"
                    Grid.Row="0"
                    x:Name="travelModeSwitch"
                    Toggled="OnModeSwitch" 
                    />

        </Grid>
    </VerticalStackLayout>
</ContentPage>